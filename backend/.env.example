###############################################
# DATABASE
###############################################
DATABASE_URL=postgresql://postgres:ashakur123@localhost:5432/tudor_padel?schema=public

###############################################
# APPLICATION
###############################################
NODE_ENV=development
JWT_SECRET=
APP_BASE_URL=http://localhost:5173
# Additional allowed origins for WebSocket (comma-separated)
# Add production URLs when deploying: https://tudorpadel.com,https://www.tudorpadel.com
ALLOWED_ORIGINS=


###############################################
# SMTP / EMAIL
###############################################
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=9e94b6001@smtp-brevo.com
# Dev pass:
SMTP_PASS=
# Prod pass:
SMTP_SECURE=false
MAIL_FROM=



###############################################
# AUTHENTICATION / SECURITY
###############################################
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15

# Cookie Configuration
# Note: __Host- prefix requires HTTPS. Use 'accessToken' for development HTTP
ACCESS_TOKEN_COOKIE_NAME=
ACCESS_TOKEN_COOKIE_PATH=
ACCESS_TOKEN_EXPIRY=
ACCESS_TOKEN_TTL_MINUTES=
REFRESH_TOKEN_COOKIE_NAME=
REFRESH_TOKEN_COOKIE_PATH=/
REFRESH_TOKEN_TTL_DAYS=
# FORCE_SECURE_COOKIES=true for development, set to false for local HTTP
FORCE_SECURE_COOKIES=
# COOKIE_DOMAIN=.tudorpadel.com (uncomment in production for subdomain sharing)

###############################################
# M-PESA CORE (STK PUSH)
###############################################
MPESA_ENV=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_CALLBACK_URL_BASE=https://<id>.ngrok-free.app

###############################################
# M-PESA B2C REFUNDS
###############################################
MPESA_B2C_INITIATOR=TPONLINE
MPESA_B2C_SECURITY_CREDENTIAL=
MPESA_B2C_SHORTCODE=
MPESA_B2C_RESULT_URL=https://<id>.ngrok-free.app/api/payments/mpesa/b2c/result?secret=<secret>
MPESA_B2C_TIMEOUT_URL=https://<id>.ngrok-free.app/api/payments/mpesa/b2c/timeout?secret=<secret>
REFUND_REASON_DEFAULT=Customer requested refund
REFUND_SLOT_GRACE_MINUTES=0

###############################################
# M-PESA REVERSAL (Optional)
###############################################
MPESA_REVERSAL_ENABLED=true
MPESA_REVERSAL_INITIATOR=PMONLINE
MPESA_REVERSAL_CREDENTIAL=
MPESA_REVERSAL_RESULT_URL=https://<id>.ngrok-free.app/api/payments/mpesa/reversal/result?secret=<secret>
MPESA_REVERSAL_TIMEOUT_URL=https://<id>.ngrok-free.app/api/payments/mpesa/reversal/timeout?secret=<secret>

###############################################
# M-PESA CALLBACK SECURITY
###############################################
MPESA_CALLBACK_SECRET=
MPESA_CALLBACK_IP_WHITELIST=
MPESA_CALLBACK_IP_ENFORCE=
MPESA_CALLBACK_SOFT_FAIL=

###############################################
# M-PESA LOGGING / CACHING (Optional)
###############################################
MPESA_LOG_LEVEL=info
MPESA_OAUTH_CACHE_TTL=3300

