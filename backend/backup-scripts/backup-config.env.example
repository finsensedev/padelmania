# ============================================================================
# Database Backup Configuration
# ============================================================================
# IMPORTANT: Copy this file to .env.backup and fill in your actual values
# Never commit .env.backup to version control!
# ============================================================================

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tudor_padel
DB_USER=postgres
DB_PASSWORD=your_database_password

# ============================================================================
# BACKUP SETTINGS
# ============================================================================
BACKUP_DIR=/var/backups/tudor-padel
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true
BACKUP_COMPRESSION_LEVEL=6

# ============================================================================
# ENCRYPTION
# ============================================================================
BACKUP_ENCRYPT=true
BACKUP_ENCRYPTION_PASSWORD=your_strong_encryption_password_min_32_chars
BACKUP_ENCRYPTION_ALGORITHM=aes-256-cbc

# ============================================================================
# CLOUD STORAGE
# ============================================================================
# Enable cloud backup
CLOUD_BACKUP_ENABLED=true

# Choose your cloud provider(s): google-drive, onedrive, or none
# You can use MULTIPLE providers by separating with commas (recommended for redundancy!)
# Examples:
#   CLOUD_PROVIDERS=google-drive              (single provider)
#   CLOUD_PROVIDERS=google-drive,onedrive     (backup to both - RECOMMENDED!)
CLOUD_PROVIDERS=google-drive

# For backward compatibility (if CLOUD_PROVIDERS is not set, this will be used)
CLOUD_PROVIDER=google-drive

# ============================================================================
# GOOGLE DRIVE (if using google-drive)
# ============================================================================
# Remote name configured in rclone (run: rclone config)
GDRIVE_REMOTE_NAME=gdrive

# Folder name in Google Drive
GDRIVE_BACKUP_FOLDER=tudor-padel-backups

# Retention in days
GDRIVE_RETENTION_DAYS=60

# Auto cleanup old backups
GDRIVE_AUTO_CLEANUP=true

# ============================================================================
# MICROSOFT ONEDRIVE (if using onedrive)
# ============================================================================
# Remote name configured in rclone (run: rclone config)
ONEDRIVE_REMOTE_NAME=onedrive

# Folder name in OneDrive
ONEDRIVE_BACKUP_FOLDER=tudor-padel-backups

# Retention in days
ONEDRIVE_RETENTION_DAYS=60

# Auto cleanup old backups
ONEDRIVE_AUTO_CLEANUP=true

# ============================================================================
# NOTIFICATIONS
# ============================================================================
# Email Notifications
EMAIL_NOTIFICATIONS_ENABLED=true
BACKUP_ALERT_EMAIL=admin@tudorpadel.com
SMTP_HOST=mail.tudorpadel.com
SMTP_PORT=587
SMTP_USER=backup@tudorpadel.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=backup@tudorpadel.com

# Slack Notifications
SLACK_NOTIFICATIONS_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SMS Notifications (via Twilio)
SMS_NOTIFICATIONS_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# ============================================================================
# BACKUP VERIFICATION
# ============================================================================
BACKUP_VERIFY=true
VERIFY_SAMPLE_QUERIES=true

# ============================================================================
# MONITORING
# ============================================================================
# Webhook for monitoring systems (e.g., healthchecks.io, uptime robot)
HEALTHCHECK_URL=https://hc-ping.com/your-uuid

# Log Level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO
LOG_FILE=/var/backups/tudor-padel/logs/backup.log

# ============================================================================
# RETENTION POLICIES
# ============================================================================
# Keep daily backups for X days
DAILY_RETENTION_DAYS=30

# Keep weekly backups for X weeks
WEEKLY_RETENTION_WEEKS=12

# Keep monthly backups for X months
MONTHLY_RETENTION_MONTHS=12

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Parallel jobs for faster backup/restore
BACKUP_JOBS=4

# Backup format (custom, plain, directory, tar)
BACKUP_FORMAT=custom

# Include database statistics
BACKUP_INCLUDE_STATS=true

# Vacuum before backup (reduces size but takes longer)
BACKUP_VACUUM_BEFORE=false

# Test restore after backup
TEST_RESTORE_ENABLED=false
TEST_RESTORE_DB_NAME=tudor_padel_restore_test
