
# Database Connection (REQUIRED)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tudor_padel
DB_USER=postgres
DB_PASSWORD=ashakur123

# Backup Directory (REQUIRED)
BACKUP_DIR=/var/backups/tudor-padel

# Encryption (REQUIRED if BACKUP_ENCRYPT=true)
BACKUP_ENCRYPT=true
BACKUP_ENCRYPTION_PASSWORD=QWnw.>_7,Zyb,aH!b%x[`\l*CS/w&i+Xt}

# Retention Policies
DAILY_RETENTION_DAYS=30
WEEKLY_RETENTION_WEEKS=12
MONTHLY_RETENTION_MONTHS=12

# Compression (optional, defaults to true)
BACKUP_COMPRESSION=true
BACKUP_COMPRESSION_LEVEL=6


# Enable Cloud Backup
CLOUD_BACKUP_ENABLED=true
CLOUD_PROVIDERS=google-drive

# Google Drive Settings
GDRIVE_REMOTE_NAME=google-drive-backup
GDRIVE_BACKUP_FOLDER=tudor-padel-backups
GDRIVE_RETENTION_DAYS=60
GDRIVE_AUTO_CLEANUP=true